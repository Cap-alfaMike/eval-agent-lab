{
  "name": "accuracy_focused",
  "description": "Rubric that prioritizes correctness metrics over agent behaviour",
  "metrics": [
    {"name": "exact_match", "weight": 3.0},
    {"name": "contains_answer", "weight": 2.5},
    {"name": "semantic_similarity", "weight": 2.0},
    {"name": "levenshtein_similarity", "weight": 1.0},
    {"name": "hallucination_score", "weight": 1.5},
    {"name": "tool_selection_accuracy", "weight": 1.0},
    {"name": "reasoning_consistency", "weight": 0.5},
    {"name": "step_efficiency", "weight": 0.5}
  ],
  "default_weight": 1.0,
  "judge_weight": 2.0,
  "strict": false,
  "pass_threshold": 0.5
}
